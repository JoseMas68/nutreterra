---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CheckoutWizard from '../../islands/CheckoutWizard';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3001';
---

<Layout title="Finalizar Compra - NutreTerra">
  <Header />

  <main class="min-h-screen bg-gray-50 py-12 md:py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl md:text-4xl font-black text-gray-900 mb-8 tracking-tight text-center">
          Finalizar tu <span class="text-primary">Pedido</span>
        </h1>

        <CheckoutWizard apiUrl={API_URL} client:load />
      </div>
    </div>
  </main>

  <Footer />
</Layout>
