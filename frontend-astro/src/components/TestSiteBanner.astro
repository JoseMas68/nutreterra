---
/**
 * Banner de "Sitio de Prueba"
 * Muestra un aviso destacado en la parte superior de la página
 */
---

<div class="test-site-banner" role="alert">
  <div class="banner-content">
    <svg xmlns="http://www.w3.org/2000/svg" class="banner-icon" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
    </svg>
    <div class="banner-text">
      <strong>⚠️ Sitio de Prueba</strong> -
      <span class="banner-separator">|</span>
      <span class="banner-credentials">
        🔑 Admin: <strong>admin@nutreterra.es</strong> / <strong>admin123</strong>
      </span>
    </div>
  </div>
</div>

<style>
  .test-site-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    color: #78350f;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    padding: 0.75rem 1rem;
  }

  .banner-content {
    max-width: 7xl;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .banner-icon {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .banner-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .banner-separator {
    margin: 0 0.25rem;
    opacity: 0.7;
  }

  .banner-credentials {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: 'Courier New', monospace;
    background: rgba(255, 255, 255, 0.3);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  /* Ajustar el body para compensar el banner fijo */
  body {
    padding-top: 3.5rem;
  }

  @media (max-width: 640px) {
    .banner-content {
      flex-direction: column;
      text-align: center;
      font-size: 0.75rem;
      gap: 0.5rem;
    }

    .banner-text {
      flex-direction: column;
      gap: 0.25rem;
    }

    .banner-separator {
      display: none;
    }

    .banner-credentials {
      font-size: 0.7rem;
      padding: 0.25rem 0.35rem;
    }

    .banner-icon {
      width: 1rem;
      height: 1rem;
    }

    body {
      padding-top: 5rem;
    }
  }
</style>
